@page "/purchase-report-demo"
@namespace NavigationSandbox.Web.Pages

<h4 class="fw-bold mb-1">Módulo de Compras</h4>
<p class="text-muted mb-4">Órdenes de compra registradas en el sistema.</p>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">Orden</th>
                    <th>Proveedor</th>
                    <th>Fecha</th>
                    <th>Monto</th>
                    <th>Estatus</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="ps-3">OC-001</td>
                    <td>Proveedor Alfa</td>
                    <td>2025-06-01</td>
                    <td>$12,500.00</td>
                    <td><span class="badge bg-success">Completada</span></td>
                </tr>
                <tr>
                    <td class="ps-3">OC-002</td>
                    <td>Proveedor Beta</td>
                    <td>2025-06-10</td>
                    <td>$8,300.00</td>
                    <td><span class="badge bg-warning text-dark">Pendiente</span></td>
                </tr>
                <tr>
                    <td class="ps-3">OC-003</td>
                    <td>Proveedor Gamma</td>
                    <td>2025-06-18</td>
                    <td>$21,000.00</td>
                    <td><span class="badge bg-secondary">Revisión</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
