@page "/"
@namespace NavigationSandbox.Web.Pages

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-truck fs-2 text-primary"></i>
                <div>
                    <div class="fw-semibold">Operación</div>
                    <div class="text-muted small">Órdenes, facturas y clientes</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-cart3 fs-2 text-success"></i>
                <div>
                    <div class="fw-semibold">Compras</div>
                    <div class="text-muted small">Órdenes de compra y proveedores</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-archive fs-2 text-warning"></i>
                <div>
                    <div class="fw-semibold">Almacén</div>
                    <div class="text-muted small">Inventario y consumos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-bar-chart-line fs-2 text-info"></i>
                <div>
                    <div class="fw-semibold">Reportes</div>
                    <div class="text-muted small">Métricas y reportes estratégicos</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-gear fs-2 text-secondary"></i>
                <div>
                    <div class="fw-semibold">Configuración</div>
                    <div class="text-muted small">Parámetros y usuarios</div>
                </div>
            </div>
        </div>
    </div>
</div>
