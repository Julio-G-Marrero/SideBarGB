@page "/inventory-demo"
@namespace NavigationSandbox.Web.Pages

<h4 class="fw-bold mb-1">Inventario</h4>
<p class="text-muted mb-4">Stock actual de materiales en almacén.</p>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-3">Código</th>
                    <th>Producto</th>
                    <th>Stock</th>
                    <th>Unidad</th>
                    <th>Estatus</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="ps-3">MAT-001</td>
                    <td>Aceite Motor 10W-40</td>
                    <td>120</td>
                    <td>Litros</td>
                    <td><span class="badge bg-success">Normal</span></td>
                </tr>
                <tr>
                    <td class="ps-3">MAT-002</td>
                    <td>Filtro de Aire</td>
                    <td>8</td>
                    <td>Piezas</td>
                    <td><span class="badge bg-danger">Stock mínimo</span></td>
                </tr>
                <tr>
                    <td class="ps-3">MAT-003</td>
                    <td>Frenos de Disco</td>
                    <td>45</td>
                    <td>Juegos</td>
                    <td><span class="badge bg-success">Normal</span></td>
                </tr>
                <tr>
                    <td class="ps-3">MAT-004</td>
                    <td>Bujías NGK</td>
                    <td>200</td>
                    <td>Piezas</td>
                    <td><span class="badge bg-success">Normal</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
