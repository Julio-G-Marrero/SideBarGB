@page "/settings-demo"
@namespace NavigationSandbox.Web.Pages

<h4 class="fw-bold mb-1">Parámetros del Sistema</h4>
<p class="text-muted mb-4">Configuración general de la aplicación.</p>

<div class="card border-0 shadow-sm" style="max-width: 600px;">
    <div class="card-body">
        <div class="mb-3">
            <label class="form-label fw-semibold">Nombre del sistema</label>
            <input type="text" class="form-control" value="Global Car — Niux 2.0" disabled />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Versión</label>
            <input type="text" class="form-control" value="2.0.0" disabled />
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Zona horaria</label>
            <select class="form-select">
                <option selected>America/Mexico_City (UTC-6)</option>
                <option>America/New_York (UTC-5)</option>
                <option>Europe/Madrid (UTC+1)</option>
            </select>
        </div>
        <div class="mb-4">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" checked />
                <label class="form-check-label">Notificaciones activas</label>
            </div>
        </div>
        <button class="btn btn-primary">
            <i class="bi bi-floppy me-2"></i>Guardar cambios
        </button>
    </div>
</div>
